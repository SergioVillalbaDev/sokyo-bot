# --- Configuración del bot Sokyo ---

# Cadena de conexión a MongoDB
MONGO_URI=mongodb://localhost:27017/sokyo

# Token del bot de Discord (Developer Portal -> Bot -> Token)
DISCORD_TOKEN=tu_token_de_discord

# Puerto en el que escucha la API (por defecto 3000)
PORT=3000

# Clave de la API. Si se define, todas las rutas /api (excepto /api/estado)
# exigen la cabecera "x-api-key" con este valor. DEBE coincidir con VITE_API_KEY
# del panel frontend. Déjala vacía solo en desarrollo local.
API_KEY=cambia-esta-clave-por-una-larga-y-aleatoria

# --- Portal del Cliente (login con Discord / OAuth2) ---
# En el Developer Portal -> tu app -> OAuth2: copia el Client ID y el Client Secret,
# y añade la Redirect URI EXACTA (la de abajo) en la lista de redirects de OAuth2.
DISCORD_CLIENT_ID=tu_client_id_de_discord
DISCORD_CLIENT_SECRET=tu_client_secret_de_discord
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# URL del panel/portal web (a donde se vuelve tras el login)
FRONTEND_URL=http://localhost:5173

# Secreto para firmar las sesiones del portal (cualquier cadena larga y aleatoria).
# Si se deja vacío, se usa API_KEY.
JWT_SECRET=cambia-este-secreto-de-sesion
