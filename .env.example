# --- Configuración del bot Sokyo ---

# Cadena de conexión a MongoDB
MONGO_URI=mongodb://localhost:27017/sokyo

# Token del bot de Discord (Developer Portal -> Bot -> Token)
DISCORD_TOKEN=tu_token_de_discord

# Puerto en el que escucha la API (por defecto 3000)
PORT=3000

# Clave de la API. Si se define, todas las rutas /api (excepto /api/estado)
# exigen la cabecera "x-api-key" con este valor. DEBE coincidir con VITE_API_KEY
# del panel frontend. Déjala vacía solo en desarrollo local.
API_KEY=cambia-esta-clave-por-una-larga-y-aleatoria
